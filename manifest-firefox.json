{
  "manifest_version": 3,
  "name": "WA Batch Tagger",
  "version": "1.3",
  "description": "Expands aliases into tags on WhatsApp Web.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "wa-tagger@binish.local",
      "strict_min_version": "109.0"
    }
  }
}